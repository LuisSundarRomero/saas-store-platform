# ─── Supabase ────────────────────────────────────────────────────
# Obtener en: Supabase → Settings → API

NEXT_PUBLIC_SUPABASE_URL=https://xxxxxxxxxxxx.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ⚠️ SOLO en servidor — nunca en Client Components
SUPABASE_SERVICE_ROLE_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# ─── Culqi ───────────────────────────────────────────────────────
# Obtener en: panel.culqi.com → Desarrollo → API Keys
# Fallback global; cada tenant puede sobrescribir con sus propias keys
# en la tabla tenants (columnas culqi_public_key / culqi_secret_key)

NEXT_PUBLIC_CULQI_PUBLIC_KEY=pk_test_xxxxxxxxxxxx
CULQI_SECRET_KEY=sk_test_xxxxxxxxxxxx

# ─── Resend ──────────────────────────────────────────────────────
# Obtener en: resend.com → API Keys
# Usado para emails de confirmación de pedido

RESEND_API_KEY=re_xxxxxxxxxxxx

# ─── Cloudflare Turnstile ────────────────────────────────────────
# Obtener en: dash.cloudflare.com → Turnstile → Crear sitio
# Protege el login del admin contra bots

NEXT_PUBLIC_TURNSTILE_SITE_KEY=0x4AAAAAAA...
TURNSTILE_SECRET_KEY=0x4AAAAAAA...

# ─── App ─────────────────────────────────────────────────────────
# En desarrollo: http://localhost:3000
# En producción: https://[slug].contahorro.com

NEXT_PUBLIC_APP_URL=http://localhost:3000
NEXT_PUBLIC_MAIN_DOMAIN=contahorro.com

# ─── Integraciones opcionales ────────────────────────────────────
# WhatsApp fallback global (cada tenant configura el suyo en /admin/configuracion)
NEXT_PUBLIC_WHATSAPP_NUMBER=51987654321

# Google Tag Manager (opcional)
NEXT_PUBLIC_GTM_ID=GTM-XXXXXXX
